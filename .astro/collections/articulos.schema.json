{
  "$ref": "#/definitions/articulos",
  "definitions": {
    "articulos": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "maxLength": 160
        },
        "category": {
          "type": "string",
          "enum": [
            "irpf",
            "autonomos",
            "inversiones",
            "deducciones",
            "fiscalidad-internacional"
          ]
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "datePublished": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "dateModified": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "author": {
          "type": "string",
          "default": "Equipo editorial de Finanzas Para Todos"
        },
        "canonical": {
          "type": "string",
          "format": "uri"
        },
        "noindex": {
          "type": "boolean",
          "default": false
        },
        "adSlots": {
          "type": "boolean",
          "default": true
        },
        "pillar": {
          "type": "boolean",
          "default": false
        },
        "relatedPosts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "schema": {
          "type": "string",
          "enum": [
            "article",
            "faq",
            "howto"
          ],
          "default": "article"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "category",
        "datePublished"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
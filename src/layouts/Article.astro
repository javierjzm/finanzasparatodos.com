---
import Base from './Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AdSlot from '../components/AdSlot.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getCollection } from 'astro:content';
import { absoluteCoverUrl, resolveArticleCover } from '../utils/covers';

interface Props {
  title: string;
  description: string;
  category: string;
  canonical?: string;
  datePublished: Date;
  dateModified?: Date;
  author?: string;
  headings: { depth: number; slug: string; text: string }[];
  relatedSlugs?: string[];
  schema?: 'article' | 'faq' | 'howto';
  faqs?: { q: string; a: string }[];
  coverImage?: string | null;
  imageAlt?: string | null;
}

const {
  title,
  description,
  category,
  canonical,
  datePublished,
  dateModified,
  author = 'Equipo editorial de Finanzas Guías',
  headings,
  relatedSlugs = [],
  schema = 'article',
  faqs = [],
  coverImage,
  imageAlt,
} = Astro.props;

const categoryNames: Record<string, string> = {
  irpf: 'IRPF',
  autonomos: 'Autónomos',
  inversiones: 'Inversiones',
  cripto: 'Criptomonedas',
  deducciones: 'Deducciones',
  'fiscalidad-internacional': 'Fiscalidad Internacional',
};

const categoryLabel = categoryNames[category] || category;
const pubDate = datePublished.toISOString().split('T')[0];
const modDate = dateModified ? dateModified.toISOString().split('T')[0] : null;

/** Canonical del artículo alineada con trailingSlash y og:url (evita @id distinto del canonical). */
const siteBase = Astro.site?.href ?? 'https://finanzasguias.com/';
const pathNormalized = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const articlePageUrl = new URL(pathNormalized, siteBase).href;

const coverPath = resolveArticleCover(category, coverImage ?? undefined);
const coverAlt =
  (imageAlt && String(imageAlt).trim()) || `Ilustración del artículo: ${title}`;
const coverAbsolute = absoluteCoverUrl(siteBase, coverPath);

const breadcrumbItems = [
  { label: 'Inicio', href: '/' },
  { label: categoryLabel, href: `/${category}/` },
  { label: title, href: pathNormalized },
];

const allArticles = await getCollection('articulos');
const relatedPosts = relatedSlugs
  .map((slug) => allArticles.find((a) => a.slug === slug))
  .filter(Boolean)
  .map((a) => ({
    title: a!.data.title,
    description: a!.data.description,
    href: `/${a!.data.category}/${a!.slug}/`,
    coverSrc: resolveArticleCover(a!.data.category, a!.data.coverImage),
    imageAlt: a!.data.imageAlt ?? a!.data.title,
  }));

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: articlePageUrl,
  image: {
    '@type': 'ImageObject',
    url: coverAbsolute,
  },
  author: {
    '@type': 'Person',
    name: author,
    url: 'https://finanzasguias.com/sobre-nosotros/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Finanzas Guías',
    url: 'https://finanzasguias.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://finanzasguias.com/favicon.svg',
      width: 512,
      height: 512,
    },
  },
  datePublished: datePublished.toISOString(),
  dateModified: (dateModified || datePublished).toISOString(),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articlePageUrl,
  },
  inLanguage: 'es-ES',
};

const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const howtoHeadings = schema === 'howto'
  ? headings.filter((h) => h.depth === 2).map((h, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      name: h.text,
      url: `${articlePageUrl}#${h.slug}`,
    }))
  : [];

const howtoSchema = schema === 'howto' && howtoHeadings.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: title,
  description,
  step: howtoHeadings,
} : null;
---

<Base
  title={`${title} | Finanzas Guías`}
  description={description}
  canonical={canonical ?? articlePageUrl}
  ogImage={coverPath}
  ogType="article"
  articlePublishedTime={datePublished.toISOString()}
  articleModifiedTime={(dateModified || datePublished).toISOString()}
  articleAuthor={author}
>
  <div class="article-layout">
    <div class="article-main">
      <Breadcrumb items={breadcrumbItems} />

      <AdSlot slot="top-banner" size="banner" />

      <header class="article-header">
        <a class="article-category-pill" href={`/${category}/`}>{categoryLabel}</a>
        <h1 class="article-title">{title}</h1>
        <p class="article-lead">
          {description}
        </p>
        <div class="article-meta" role="group" aria-label="Datos de publicación">
          <span class="article-meta__item">
            <span class="article-meta__key">Publicado</span>
            <time datetime={pubDate}>{pubDate}</time>
          </span>
          {modDate && modDate !== pubDate && (
            <span class="article-meta__item">
              <span class="article-meta__key">Actualizado</span>
              <time datetime={modDate}>{modDate}</time>
            </span>
          )}
          <span class="article-meta__item article-meta__item--author">
            <span class="article-meta__key">Redacción</span>
            <span>{author}</span>
          </span>
        </div>
      </header>

      <figure class="article-cover">
        <img
          src={coverPath}
          alt={coverAlt}
          width="1200"
          height="630"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="toc-mobile-wrap">
        <TableOfContents headings={headings} variant="collapsible" />
      </div>

      <div class="disclaimer-box" role="note">
        <strong class="disclaimer-box__title">Información orientativa</strong>
        <p class="disclaimer-box__text">
          Este artículo no constituye asesoramiento fiscal, legal ni financiero personalizado. Consulta con un profesional antes de tomar decisiones que afecten a tu situación particular.
        </p>
      </div>

      <article class="article-reading">
        <div class="article-content">
          <slot />
        </div>
      </article>

      <!-- AD_SLOT: in-content (se inserta automáticamente tras el segundo párrafo) -->
      <div id="in-content-ad-anchor">
        <AdSlot slot="in-content" size="rectangle" />
      </div>

      <!-- AD_SLOT: below-content -->
      <AdSlot slot="below-content" size="rectangle" />

      {relatedPosts.length > 0 && <RelatedPosts posts={relatedPosts} />}
    </div>

    <aside class="article-sidebar" aria-label="Índice y publicidad">
      <div class="sidebar-sticky">
        <TableOfContents headings={headings} variant="sidebar" />
        <!-- AD_SLOT: sidebar -->
        <AdSlot slot="sidebar" size="sidebar" desktopOnly />
      </div>
    </aside>
  </div>

  <!-- AD_SLOT: anchor-mobile (fixed bottom, mobile only) -->
  <AdSlot slot="anchor-mobile" size="anchor" mobileOnly />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  {howtoSchema && <script type="application/ld+json" set:html={JSON.stringify(howtoSchema)} />}
  <script is:inline>
    (function () {
      var anchor = document.getElementById('in-content-ad-anchor');
      var content = document.querySelector('.article-content');
      if (!anchor || !content) return;
      var paragraphs = content.querySelectorAll('p');
      if (paragraphs.length >= 2) {
        paragraphs[1].insertAdjacentElement('afterend', anchor);
      } else {
        content.appendChild(anchor);
      }
    })();
  </script>
</Base>

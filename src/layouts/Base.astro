---
import CookieBanner from '../components/CookieBanner.astro';
import { SITE_ORIGIN } from '../config/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** Open Graph: artículos usan tipo `article` para mejor compartido en redes. */
  ogType?: 'website' | 'article';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
}

/** Evita http y rutas sin / final: reduce errores de redirección en Google. */
function normalizeCanonical(href: string): string {
  try {
    const u = new URL(href);
    let path = u.pathname;
    if (path !== '/' && !path.endsWith('/')) path += '/';
    return `${SITE_ORIGIN}${path}`;
  } catch {
    return href;
  }
}

const {
  title,
  description,
  canonical: canonicalProp,
  ogImage = '/images/brand/home-hero.jpg',
  noindex = false,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
} = Astro.props;

const canonical = canonicalProp
  ? normalizeCanonical(canonicalProp)
  : normalizeCanonical(Astro.url.href);

const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : `${SITE_ORIGIN}${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`;

const siteName = 'Finanzas Guías';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: 'https://finanzasguias.com',
  description:
    'Guías fiscales claras para leer online: IRPF, autónomos, inversiones, criptomonedas y deducciones en España.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://finanzasguias.com/buscar?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: 'https://finanzasguias.com',
  logo: {
    '@type': 'ImageObject',
    url: 'https://finanzasguias.com/favicon.svg',
    width: 512,
    height: 512,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'hola@finanzasguias.com',
    contactType: 'customer service',
    availableLanguage: 'Spanish',
  },
};
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Consent Mode por defecto (antes de GTM y AdSense) -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      wait_for_update: 500,
    });
  </script>
  <!-- Google Tag Manager -->
  <script is:inline>
    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
      var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s),
        dl = l != 'dataLayer' ? '&l=' + l : '';
      j.async = true;
      j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
      f.parentNode.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', 'GTM-WSLWLFNS');
  </script>
  <script
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8300766188725023"
    crossorigin="anonymous"></script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" title="Finanzas Guías — RSS" href="https://finanzasguias.com/rss.xml" />
  {noindex ? <meta name="robots" content="noindex, follow" /> : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}
  <meta name="theme-color" content="#1a1a1a" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:site_name" content={siteName} />
  {ogType === 'article' && articlePublishedTime && (
    <meta property="article:published_time" content={articlePublishedTime} />
  )}
  {ogType === 'article' && articleModifiedTime && (
    <meta property="article:modified_time" content={articleModifiedTime} />
  )}
  {ogType === 'article' && articleAuthor && (
    <meta property="article:author" content={articleAuthor} />
  )}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap"
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
</head>
<body>
  <noscript>
    <iframe
      src="https://www.googletagmanager.com/ns.html?id=GTM-WSLWLFNS"
      height="0"
      width="0"
      style="display: none; visibility: hidden"
      title="Google Tag Manager"></iframe>
  </noscript>
  <header class="site-header">
    <div class="site-brand-strip" aria-hidden="true"></div>
    <div class="header-inner">
      <a href="/" class="site-logo" aria-label="Finanzas Guías — Ir al inicio">finanzas<strong>guías</strong></a>
      <nav class="main-nav">
        <a href="/irpf/">IRPF</a>
        <a href="/autonomos/">Autónomos</a>
        <a href="/inversiones/">Inversiones</a>
        <a href="/cripto/">Cripto</a>
        <a href="/deducciones/">Deducciones</a>
        <a href="/fiscalidad-internacional/">Internacional</a>
        <a href="/calculadora-fiscal/" class="nav-calc-link">Comparador fiscal</a>
        <form action="/buscar/" method="get" class="nav-search-form" role="search">
          <input
            type="search"
            name="q"
            class="nav-search"
            placeholder="Buscar…"
            aria-label="Buscar en el sitio"
          />
        </form>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-links">
      <a href="/calculadora-fiscal/">Calculadora fiscal</a>
      <a href="/sobre-nosotros/">Sobre nosotros</a>
      <a href="/politica-privacidad/">Privacidad</a>
      <a href="/aviso-legal/">Aviso legal</a>
      <a href="/politica-cookies/">Cookies</a>
      <a href="/contacto/">Contacto</a>
    </div>
    <p>&copy; {new Date().getFullYear()} finanzasguias.com. Todos los derechos reservados.</p>
    <p class="footer-disclaimer">Contenido informativo. No constituye asesoramiento fiscal, legal ni financiero personalizado.</p>
  </footer>

  <CookieBanner />
</body>
</html>

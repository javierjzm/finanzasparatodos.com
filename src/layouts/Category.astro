---
import Base from './Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AdSlot from '../components/AdSlot.astro';
import { absoluteUrl } from '../config/site';

interface ArticleCard {
  title: string;
  description: string;
  href: string;
  date: string;
  coverSrc: string;
  imageAlt: string;
}

interface Props {
  categoryName: string;
  categorySlug: string;
  description: string;
  metaDescription: string;
  articles: ArticleCard[];
}

const { categoryName, categorySlug, description, metaDescription, articles } = Astro.props;

const breadcrumbItems = [
  { label: 'Inicio', href: '/' },
  { label: categoryName, href: `/${categorySlug}/` },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: categoryName,
  description: metaDescription,
  numberOfItems: articles.length,
  itemListElement: articles.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: a.title,
    url: absoluteUrl(a.href),
  })),
};
---

<Base title={`${categoryName} | Finanzas Guías`} description={metaDescription}>
  <div class="container category-page">
    <Breadcrumb items={breadcrumbItems} />

    <header class="category-header">
      <h1 class="section-title category-header__title">{categoryName}</h1>
      <p class="category-lead" set:html={description} />
    </header>

    <div class="articles-grid">
      {articles.map((article, index) => (
        <>
          <a href={article.href} class="article-card">
            <div class="article-card__media">
              <img
                src={article.coverSrc}
                alt={article.imageAlt}
                width="248"
                height="186"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="article-card__body">
              <h3>{article.title}</h3>
              <p class="card-description">{article.description}</p>
              <span class="card-date">{article.date}</span>
            </div>
          </a>
          {index === 3 && <AdSlot slot={`category-${categorySlug}`} size="rectangle" />}
        </>
      ))}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
</Base>

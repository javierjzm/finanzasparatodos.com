---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import { getCollection } from 'astro:content';
import { resolveArticleCover } from '../utils/covers';

const allArticles = await getCollection('articulos');
const recentArticles = allArticles
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime())
  .slice(0, 6);
const featuredArticle = recentArticles[0];
const latestArticles = recentArticles.slice(1);
const mostRead = [
  { title: 'Tramos IRPF 2025: cuánto pagas según ingresos', href: '/irpf/tramos-irpf-2025/' },
  { title: 'Modelo 130 para autónomos: qué es y cómo se presenta', href: '/autonomos/modelo-130/' },
  { title: 'Deducción por vivienda habitual: requisitos y límites', href: '/deducciones/deduccion-vivienda-habitual/' },
  { title: 'Cómo declarar criptomonedas en el IRPF en España', href: '/cripto/declarar-criptomonedas-irpf-espana/' },
];

const startHere = [
  {
    title: 'Empieza por IRPF',
    desc: 'Si eres asalariado o mezclas rentas, aquí tienes la base.',
    href: '/irpf/',
    category: 'irpf' as const,
  },
  {
    title: 'Si eres autónomo',
    desc: 'Cuotas, gastos deducibles y modelos trimestrales esenciales.',
    href: '/autonomos/',
    category: 'autonomos' as const,
  },
  {
    title: 'Compara fiscalidad internacional',
    desc: 'Residencia fiscal y convenios para evitar doble imposición.',
    href: '/fiscalidad-internacional/',
    category: 'fiscalidad-internacional' as const,
  },
];

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Base
  title="Fiscalidad en España: IRPF, autónomos, inversiones, cripto y deducciones | Finanzas Guías"
  description="Guías claras y actualizadas sobre IRPF, fiscalidad para autónomos, inversiones, criptomonedas y deducciones. Información fiscal práctica para particulares en España."
  ogImage="/images/brand/home-hero.jpg"
>
  <section class="hero">
    <div class="hero-banner">
      <img
        src="/images/brand/home-hero.jpg"
        alt="Cabecera visual de Finanzas Guías: guías fiscales en España"
        width="1600"
        height="600"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <p class="hero-kicker">Guías fiscales para decidir mejor</p>
    <h1>Guías de fiscalidad en España: IRPF, autónomos, inversiones, criptomonedas y deducciones</h1>
    <p>
      Guías prácticas y actualizadas sobre impuestos, deducciones y obligaciones fiscales
      para que tomes mejores decisiones con tu dinero.
    </p>
    <div class="hero-quick-links" aria-label="Accesos rápidos">
      <a href="/irpf/tramos-irpf-2025/">Tramos IRPF</a>
      <a href="/autonomos/modelo-130/">Modelo 130</a>
      <a href="/deducciones/deduccion-vivienda-habitual/">Deducción vivienda</a>
      <a href="/calculadora-fiscal/">Comparador fiscal</a>
    </div>
  </section>

  <AdSlot slot="after-hero" size="banner" />

  <section class="container home-section">
    <div class="home-calc-cta">
      <div class="home-calc-cta-inner">
        <div class="home-calc-cta-copy">
          <span class="home-calc-cta-kicker">Herramienta destacada</span>
          <h2>Comparador fiscal: España vs otros países</h2>
          <p>Simula en menos de 1 minuto cuánto pagarías en España frente a Francia, Alemania, Italia, Portugal, Reino Unido o Andorra.</p>
          <ul class="home-calc-cta-points">
            <li>Incluye IRPF, cotizaciones y patrimonio</li>
            <li>Comparativa inmediata por salario y comunidad</li>
            <li>Enfoque práctico para decidir residencia fiscal</li>
          </ul>
        </div>
        <div class="home-calc-cta-action">
          <a href="/calculadora-fiscal/" class="btn btn-primary">Abrir comparador gratis</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container home-section">
    <div class="home-intent-layout">
      <div class="home-most-read">
        <h2 class="section-title">Lo más leído</h2>
        <ol>
          {mostRead.map((item) => (
            <li>
              <a href={item.href}>{item.title}</a>
            </li>
          ))}
        </ol>
      </div>
      <div class="home-start-here">
        <h2 class="section-title">Empieza aquí</h2>
        <div class="home-start-grid">
          {startHere.map((item) => (
            <a href={item.href} class="home-start-card">
              <div class="home-start-card__thumb" aria-hidden="true">
                <img
                  src={resolveArticleCover(item.category)}
                  alt=""
                  width="120"
                  height="68"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="home-start-card__text">
                <h3>{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container home-section">
    <h2 class="section-title">Lo más reciente y útil</h2>
    <p class="section-subtitle">Empieza por lo importante: última guía publicada y artículos clave del momento.</p>
    <div class="home-latest-layout">
      {featuredArticle && (
        <a href={`/${featuredArticle.data.category}/${featuredArticle.slug}/`} class="home-featured-card">
          <div class="home-featured-card__media">
            <img
              src={resolveArticleCover(featuredArticle.data.category, featuredArticle.data.coverImage)}
              alt={featuredArticle.data.imageAlt ?? featuredArticle.data.title}
              width="640"
              height="360"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
          <div class="home-featured-card__body">
            <span class="home-featured-card__label">Destacado</span>
            <h3>{featuredArticle.data.title}</h3>
            <p>{featuredArticle.data.description}</p>
            <span class="home-featured-card__date">{formatDate(featuredArticle.data.datePublished)}</span>
          </div>
        </a>
      )}
      <div class="home-latest-list">
        {latestArticles.map((article) => (
          <a href={`/${article.data.category}/${article.slug}/`} class="home-latest-item">
            <div class="home-latest-item__thumb" aria-hidden="true">
              <img
                src={resolveArticleCover(article.data.category, article.data.coverImage)}
                alt=""
                width="160"
                height="90"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="home-latest-item__main">
              <h3>{article.data.title}</h3>
              <span class="home-latest-item__date">{formatDate(article.data.datePublished)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <AdSlot slot="after-recent-posts" size="rectangle" />
</Base>

---
import Category from '../../layouts/Category.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articulos');
const articles = allArticles
  .filter((a) => a.data.category === 'cripto')
  .sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime())
  .map((a) => ({
    title: a.data.title,
    description: a.data.description,
    href: `/cripto/${a.slug}/`,
    date: a.data.datePublished.toLocaleDateString('es-ES', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }),
  }));

const description = `Las criptomonedas y demás criptoactivos han pasado de ser un nicho tecnológico a un activo que Hacienda mira con lupa: plusvalías en la venta o el intercambio, obligaciones informativas cuando la custodia está en el extranjero y la necesidad de encajar cada operación en el IRPF. En esta sección reunimos guías pensadas para el residente fiscal en España, con referencia a la normativa y a los criterios publicados por la Agencia Tributaria, sin sustituir el asesoramiento personalizado de un gestor o economista colegiado.`;
---

<Category
  categoryName="Criptomonedas y fiscalidad en España"
  categorySlug="cripto"
  description={description}
  metaDescription="Fiscalidad de criptomonedas en España: cómo declarar bitcoin y altcoins en el IRPF, modelo 721, plusvalías y obligaciones para residentes. Guías prácticas."
  articles={articles}
/>

---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = 'Calculadora de impuestos en España 2026 — Compara con tu país';
const description = 'Compara cuánto pagarías en impuestos en España frente a Francia, Alemania, Italia, Portugal, Reino Unido, Rusia o Andorra. Simulador de IRPF, cotizaciones y patrimonio. Gratis.';

const breadcrumbs = [
  { label: 'Inicio', href: '/' },
  { label: 'Calculadora fiscal', href: '/calculadora-fiscal/' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Cuánto se paga de IRPF en España según comunidad autónoma?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El IRPF en España es progresivo y combina un tramo estatal y otro autonómico. El tipo marginal máximo oscila entre el 45 % en Madrid y el 54 % en Cataluña. La comunidad autónoma con menor carga fiscal es Madrid, mientras que Cataluña y Extremadura son de las más altas.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Es España más barata fiscalmente que Francia o Alemania?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Para salarios medios-altos (50.000-150.000 € brutos), España suele ser más barata en términos de carga fiscal total que Francia, Alemania, Italia o Portugal. Esto se debe principalmente a que la Seguridad Social española está topada en torno a 56.600 €, mientras que en Francia o Alemania las cotizaciones escalan con el salario. El simulador te muestra la diferencia exacta con tu salario.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué impuestos incluye la calculadora?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La calculadora incluye IRPF (o equivalente en cada país), cotizaciones sociales a cargo del trabajador o autónomo, e impuesto de patrimonio para el caso de España (excluyendo comunidades que lo tienen bonificado al 100 %, como Madrid). No incluye IVA, impuestos municipales ni contribuciones del empleador.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué ocurre si el resultado sale negativo (España más cara)?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Para ciertos países y salarios —como el Reino Unido en salarios medios o Andorra en cualquier tramo— España puede resultar fiscalmente más cara. La calculadora lo muestra en rojo indicando "Pagarías más en España". Esto es especialmente útil para extranjeros que evalúan si establecer su residencia fiscal en España.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Esta calculadora es exacta?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Es una estimación orientativa basada en la normativa 2026. No sustituye el asesoramiento fiscal profesional. Factores como deducciones personales, convenios internacionales de doble imposición, regímenes especiales (Ley Beckham) o rentas mixtas pueden alterar el resultado.',
      },
    },
  ],
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Calculadora de impuestos en España vs otros países 2026',
  url: 'https://finanzasguias.com/calculadora-fiscal/',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
  description: description,
};
---

<Base title={title} description={description}>
  <div class="container">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section class="calc-hero">
    <h1>Comparador de impuestos: España vs tu país 2026</h1>
    <p>¿Cuánto pagarías de IRPF y cotizaciones si vivieras en España? Compara con Francia, Alemania, Italia, Portugal, Reino Unido, Rusia o Andorra. Introduce tu salario y obtén el resultado al instante.</p>
  </section>

  <AdSlot slot="top-banner" size="banner" />

  <section class="calc-app" id="calculadora">
    <div class="container">
      <div class="calc-inputs">
        <div class="calc-input-row">
          <label for="salary-input">Salario bruto anual</label>
          <div class="calc-slider-combo">
            <input type="range" id="salary-slider" min="0" max="1000" value="350" step="1" aria-label="Salario bruto anual">
            <div class="calc-input-euro">
              <input type="number" id="salary-input" min="0" max="500000" value="50000" step="500">
              <span class="calc-euro">€</span>
            </div>
          </div>
        </div>

        <div class="calc-selects">
          <div class="calc-field">
            <label for="pais">Tu país actual</label>
            <select id="pais">
              <option value="francia" selected>Francia 🇫🇷</option>
              <option value="portugal">Portugal 🇵🇹</option>
              <option value="italia">Italia 🇮🇹</option>
              <option value="alemania">Alemania 🇩🇪</option>
              <option value="uk">Reino Unido 🇬🇧</option>
              <option value="rusia">Rusia 🇷🇺</option>
              <option value="andorra">Andorra 🇦🇩</option>
            </select>
          </div>

          <div class="calc-field">
            <label for="comunidad">Comunidad autónoma en España</label>
            <select id="comunidad">
              <option value="madrid" selected>Madrid</option>
              <option value="cataluna">Cataluña</option>
              <option value="andalucia">Andalucía</option>
              <option value="valencia">C. Valenciana</option>
              <option value="galicia">Galicia</option>
              <option value="castilla-leon">Castilla y León</option>
              <option value="pais-vasco">País Vasco</option>
              <option value="canarias">Canarias</option>
              <option value="castilla-mancha">Castilla-La Mancha</option>
              <option value="murcia">R. de Murcia</option>
              <option value="aragon">Aragón</option>
              <option value="extremadura">Extremadura</option>
              <option value="baleares">Islas Baleares</option>
              <option value="asturias">Asturias</option>
              <option value="navarra">Navarra</option>
              <option value="cantabria">Cantabria</option>
              <option value="rioja">La Rioja</option>
            </select>
          </div>

          <div class="calc-field">
            <label for="situacion">Situación familiar</label>
            <select id="situacion">
              <option value="soltero" selected>Soltero/a</option>
              <option value="casado-0">Casado/a sin hijos</option>
              <option value="casado-1">Casado/a 1 hijo</option>
              <option value="casado-2">Casado/a 2+ hijos</option>
            </select>
          </div>

          <div class="calc-field calc-field-pills">
            <label>Tipo de renta</label>
            <div class="calc-pills">
              <input type="radio" id="renta-asalariado" name="tipo-renta" value="asalariado" checked>
              <label for="renta-asalariado">Asalariado</label>
              <input type="radio" id="renta-autonomo" name="tipo-renta" value="autonomo">
              <label for="renta-autonomo">Autónomo</label>
              <input type="radio" id="renta-dividendos" name="tipo-renta" value="dividendos">
              <label for="renta-dividendos">Capital</label>
            </div>
          </div>
        </div>

        <details class="calc-patrimony-toggle">
          <summary>Patrimonio neto (opcional, para Impuesto de Patrimonio en España)</summary>
          <div class="calc-slider-combo">
            <input type="range" id="patrimony-slider" min="0" max="5000000" value="0" step="10000" aria-label="Patrimonio neto">
            <div class="calc-input-euro">
              <input type="number" id="patrimony-input" min="0" max="5000000" value="0" step="10000">
              <span class="calc-euro">€</span>
            </div>
          </div>
        </details>
      </div>

      <div class="calc-savings-banner calc-savings-positive" aria-live="polite">
        <div class="calc-savings-label"><span id="savings-label-text">Ahorrarías en España frente a tu país</span></div>
        <div class="calc-savings-amount"><span id="ahorro-anual">3.791 €</span><span class="calc-savings-per"> / año</span></div>
        <div class="calc-savings-sub">
          <span id="ahorro-mensual">316 €</span>/mes &middot;
          <span id="ahorro-5">18.955 €</span> en 5 años &middot;
          <span id="ahorro-10">37.910 €</span> en 10 años
        </div>
      </div>

      <div class="calc-comparison" aria-live="polite">
        <div class="calc-card calc-card-origin">
          <div class="calc-card-header">
            <span class="calc-card-name" id="origin-name">Francia</span>
            <span class="calc-card-neto" id="origin-neto">34.014 €</span>
          </div>
          <div class="calc-tax-bar"><div class="calc-tax-bar-fill calc-bar-origin" id="origin-bar" style="width:32%"></div></div>
          <div class="calc-card-detail">
            <div class="calc-detail-row"><span id="origin-ss-label">Cotisations sociales</span><span id="origin-ss">-11.000 €</span></div>
            <div class="calc-detail-row"><span id="origin-irpf-label">Impôt sur le revenu</span><span id="origin-irpf">-4.986 €</span></div>
            <div class="calc-detail-row calc-detail-tipo"><span>Tipo efectivo</span><span id="origin-tipo">32,0 %</span></div>
          </div>
        </div>

        <div class="calc-card calc-card-spain">
          <div class="calc-card-header">
            <span class="calc-card-name">España 🇪🇸</span>
            <span class="calc-card-neto" id="spain-neto">37.805 €</span>
          </div>
          <div class="calc-tax-bar"><div class="calc-tax-bar-fill calc-bar-spain" id="spain-bar" style="width:24%"></div></div>
          <div class="calc-card-detail">
            <div class="calc-detail-row"><span>Seg. Social</span><span id="spain-ss">-3.235 €</span></div>
            <div class="calc-detail-row"><span>IRPF</span><span id="spain-irpf">-8.960 €</span></div>
            <div class="calc-detail-row" id="spain-ip-row" style="display:none"><span>I. Patrimonio</span><span id="spain-ip">0 €</span></div>
            <div class="calc-detail-row calc-detail-tipo"><span>Tipo efectivo</span><span id="spain-tipo">24,4 %</span></div>
          </div>
        </div>
      </div>

      <noscript>
        <div class="disclaimer-box">
          Para utilizar la calculadora interactiva necesitas tener JavaScript activado en tu navegador. Mientras tanto, consulta la tabla comparativa más abajo.
        </div>
      </noscript>
    </div>
  </section>

  <AdSlot slot="in-content" size="rectangle" />

  <section class="calc-table-section" id="comparativa">
    <div class="container">
      <h2>Comparativa: España vs otros países (50.000 € brutos, soltero, asalariado)</h2>
      <p class="calc-table-subtitle">Estimación para asalariado soltero con 50.000 € de salario bruto. España calculada con residencia en Madrid. Valores orientativos 2026.</p>
      <div class="data-table">
        <table>
          <thead>
            <tr>
              <th>País de origen</th>
              <th>Neto en ese país</th>
              <th>Neto en España (Madrid)</th>
              <th>Diferencia/año</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>🇵🇹 Portugal</td><td>31.127 €</td><td rowspan="4" class="calc-spain-col">37.805 €</td><td class="calc-col-ahorro">+6.678 €</td></tr>
            <tr><td>🇩🇪 Alemania</td><td>32.641 €</td><td class="calc-col-ahorro">+5.164 €</td></tr>
            <tr><td>🇫🇷 Francia</td><td>34.014 €</td><td class="calc-col-ahorro">+3.791 €</td></tr>
            <tr><td>🇮🇹 Italia</td><td>34.828 €</td><td class="calc-col-ahorro">+2.977 €</td></tr>
            <tr><td>🇬🇧 Reino Unido</td><td>40.118 €</td><td>37.805 €</td><td class="calc-col-coste">-2.313 €</td></tr>
            <tr><td>🇦🇩 Andorra</td><td>45.500 €</td><td>37.805 €</td><td class="calc-col-coste">-7.695 €</td></tr>
          </tbody>
        </table>
      </div>
      <p class="calc-table-note">Positivo (+) = España es más barata; negativo (−) = España es más cara. Usa el simulador para ver tu caso exacto.</p>
    </div>
  </section>

  <section class="calc-content container">
    <h2>Cómo funciona el comparador fiscal España</h2>
    <p>El simulador calcula tu carga fiscal total —IRPF o equivalente, cotizaciones sociales y, si aplica, impuesto de patrimonio— en tu país actual y en España, con los datos normativos de 2026. El resultado muestra cuánto más o menos pagarías viviendo en España.</p>

    <h3>¿Para quién es útil?</h3>
    <ul>
      <li><strong>Extranjeros que se plantean mudarse a España</strong>: profesionales, nómadas digitales, jubilados o inversores que quieren saber si España es una opción fiscalmente competitiva.</li>
      <li><strong>Españoles que trabajan fuera</strong>: para comparar cuánto pagarían si volviesen o cambiasen de destino.</li>
      <li><strong>Gestores y asesores fiscales</strong>: como herramienta de orientación rápida antes de un análisis detallado.</li>
    </ul>

    <h3>Países soportados</h3>
    <p>Puedes comparar España frente a <strong>Francia, Alemania, Italia, Portugal, Reino Unido, Rusia y Andorra</strong>. Cada país tiene su propio motor de cálculo con los tramos y cotizaciones vigentes en 2026. Para España, el simulador distingue entre las 17 comunidades autónomas y sus tarifas autonómicas del IRPF.</p>

    <h3>¿Por qué España puede salir más barata que países como Francia o Alemania?</h3>
    <p>La clave está en las cotizaciones sociales. En España, la base de cotización del trabajador tiene un tope de aproximadamente 56.600 € al año (2026), lo que significa que un salario de 150.000 € cotiza igual que uno de 56.600 €. En Francia o Alemania, las cotizaciones escalan con el salario sin ese tope, lo que hace que la carga total en esos países sea mayor para rentas altas. Para las rentas más bajas o el caso del Reino Unido, la comparación puede invertirse.</p>

    <h3>La Ley Beckham: régimen especial para nuevos residentes en España</h3>
    <p>Los extranjeros que se trasladan a España por razones laborales pueden acogerse al régimen especial de impatriados (popularmente conocido como <em>Ley Beckham</em>), que aplica un tipo fijo del 24 % sobre los primeros 600.000 € de renta durante los primeros 6 años. Esta calculadora no incluye dicho régimen; si te aplica, la carga fiscal real en España sería aún menor.</p>

    <p>Consulta también nuestra <a href="/fiscalidad-internacional/impuestos-andorra-guia-completa/">guía completa sobre impuestos en Andorra</a> y el artículo sobre <a href="/fiscalidad-internacional/residencia-fiscal-espana/">cómo funciona la residencia fiscal en España</a>. Para entender en detalle la escala del IRPF, visita la guía de <a href="/irpf/tramos-irpf-2025/">tramos del IRPF 2025-2026</a>.</p>

    <div class="disclaimer-box">
      Información orientativa basada en normativa vigente en 2026. No constituye asesoramiento fiscal, legal ni financiero personalizado. Los cálculos son estimaciones y pueden diferir de la liquidación real en función de deducciones, convenios internacionales de doble imposición y otras circunstancias. Consulta siempre con un asesor fiscal cualificado.
    </div>
  </section>

  <section class="calc-faq container" id="faq">
    <h2>Preguntas frecuentes</h2>
    <div class="calc-faq-list">
      {faqSchema.mainEntity.map((q) => (
        <details class="calc-faq-item">
          <summary>{q.name}</summary>
          <p>{q.acceptedAnswer.text}</p>
        </details>
      ))}
    </div>
  </section>

  <AdSlot slot="below-content" size="rectangle" />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script src="/js/calculadora.js" defer></script>
</Base>

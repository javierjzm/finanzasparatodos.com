---
interface RelatedPost {
  title: string;
  description: string;
  href: string;
  coverSrc: string;
  imageAlt: string;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="related-posts">
    <h2>Artículos relacionados</h2>
    <div class="related-posts-grid">
      {posts.map((post) => (
        <a href={post.href} class="related-card">
          <div class="related-card__media">
            <img
              src={post.coverSrc}
              alt={post.imageAlt}
              width="640"
              height="360"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="related-card__body">
            <h3>{post.title}</h3>
            <p>{post.description.length > 100
              ? post.description.slice(0, 100) + '…'
              : post.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

---
/**
 * Marcadores de posición para anuncios. Con **anuncios automáticos** de AdSense activados
 * en el panel, Google inserta los creativos sin `data-ad-slot` ni `.env`: basta el script
 * del cliente en `Base.astro`. Estos bloques reservan espacio (min-height) y orden visual;
 * si Auto ads coloca anuncios en otras zonas, puedes ir eliminando `AdSlot` donde sobren.
 */
interface Props {
  slot: string;
  size: 'banner' | 'rectangle' | 'sidebar' | 'anchor';
  mobileOnly?: boolean;
  desktopOnly?: boolean;
}

const { slot, size, mobileOnly = false, desktopOnly = false } = Astro.props;

const sizeClasses: Record<string, string> = {
  banner: 'ad-banner',
  rectangle: 'ad-rectangle',
  sidebar: 'ad-sidebar',
  anchor: 'ad-anchor',
};

const classes = [
  'ad-slot',
  sizeClasses[size],
  mobileOnly ? 'mobile-only' : '',
  desktopOnly ? 'desktop-only' : '',
].filter(Boolean).join(' ');
---

<!-- Zona publicitaria (Auto ads): {slot} -->
<div class={classes} data-ad-slot={slot} aria-hidden="true" role="presentation"></div>
